# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it contains sensitive information)

# Groq API Key (Required for AI summaries)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# GPU Configuration (Automatically set by docker-compose files)
# Leave as false unless using docker-compose.gpu.yml
USE_GPU=false

# Model Directory (Usually no need to change)
MODEL_DIR=/app/models

# API Configuration (Usually no need to change)
ASR_HOST=127.0.0.1
ASR_PORT=8000

